# ---- Public hostname (a wildcard *.DOMAIN must resolve to this server) ----
DOMAIN=demo.example.com
ACME_EMAIL=admin@example.com

# ---- Database passwords (change every one) ----
PG_SUPER_PASSWORD=change-me-postgres-super
KC_DB_PASSWORD=change-me-keycloak-db
GITEA_DB_PASSWORD=change-me-gitea-db
GUAC_DB_PASSWORD=change-me-guacamole-db
WIKIJS_DB_PASSWORD=change-me-wikijs-db
NEXTCLOUD_DB_PASSWORD=change-me-nextcloud-db

# ---- Application admin / SSO secrets ----
KC_ADMIN_PASSWORD=change-me-keycloak-admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-nextcloud-admin
GRAFANA_OIDC_SECRET=change-me-grafana-oidc-secret   # must match the 'grafana' client secret in realm-export.json

# ---- Jitsi (only needed with compose.comms.yml) ----
JICOFO_AUTH_PASSWORD=change-me-jicofo
JVB_AUTH_PASSWORD=change-me-jvb
JITSI_SECRET=change-me-jitsi-component
